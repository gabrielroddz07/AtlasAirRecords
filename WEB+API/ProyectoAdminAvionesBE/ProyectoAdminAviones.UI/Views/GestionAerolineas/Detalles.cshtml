@model ProyectoAdminAviones.Model.Aerolinea

@{
    ViewData["Title"] = "Detalles de la aerolínea";
}

<link rel="stylesheet" href="~/css/homepage.css" />
<link rel="stylesheet" href="~/css/crud.css" />

<div class="aviones-page">

    <section class="page-header">
        <div>
            <h1>AEROLÍNEAS</h1>
            <p>Gestiona y consulta las aerolíneas registradas en el sistema.</p>
        </div>

        <div class="page-actions">
            <a asp-action="Index" class="btn-outline">
                <i class="fa-solid fa-arrow-left"></i>
                &nbsp;Volver
            </a>
        </div>
    </section>

    <!-- Vista de detalle vinculada al modelo Aerolinea. -->
    <section class="details-section">
        <div class="details-card">

            <!-- Estructura de presentación de atributos del modelo. -->
            <div class="details-grid">

                <div class="detail-item">
                    <span class="detail-label">ID</span>
                    <p>@Model.IdAerolinea</p>
                </div>

                <div class="detail-item">
                    <span class="detail-label">Nombre</span>
                    <p>@Model.Nombre</p>
                </div>

                <div class="detail-item">
                    <span class="detail-label">País</span>
                    <p>@Model.Pais</p>
                </div>

                <div class="detail-item">
                    <span class="detail-label">Fecha de fundación</span>
                    <p>@Model.FechaFundacion.ToString("dd/MM/yyyy")</p>
                </div>

                <div class="detail-item">
                    <span class="detail-label">Teléfono</span>
                    <p>@Model.Telefono</p>
                </div>

                <div class="detail-item">
                    <span class="detail-label">Correo</span>
                    <p>@Model.Correo</p>
                </div>

            </div>

            <!-- Acciones disponibles sobre la entidad mostrada. -->
            <div class="details-actions">
                <a asp-action="VerAviones" asp-route-id="@Model.IdAerolinea" class="btn-action btn-details">
                    <i class="fa-solid fa-plane"></i>
                    Ver aviones
                </a>

                <a asp-action="Editar" asp-route-id="@Model.IdAerolinea" class="btn-action btn-edit">
                    <i class="fa-solid fa-pen"></i>
                    Editar
                </a>
            </div>
        </div>
    </section>

    <section class="cards-section">
        <div class="cards">
            <a asp-controller="GestionAviones" asp-action="Index" class="card">
                <i class="fa-solid fa-plane"></i>
                <h3>Aviones</h3>
                <p>Consulta y gestiona aeronaves registradas.</p>
            </a>

            <a asp-controller="GestionAerolineas" asp-action="Index" class="card">
                <i class="fa-solid fa-building"></i>
                <h3>Aerolíneas</h3>
                <p>Explora operadores y compañías aéreas.</p>
            </a>

            <a asp-controller="GestionPropietarios" asp-action="Index" class="card">
                <i class="fa-solid fa-user"></i>
                <h3>Propietarios</h3>
                <p>Accede a información de propietarios registrados.</p>
            </a>
        </div>
    </section>

    <footer class="footer">
        <p>Atlas Air Records © 2026</p>
    </footer>

</div>