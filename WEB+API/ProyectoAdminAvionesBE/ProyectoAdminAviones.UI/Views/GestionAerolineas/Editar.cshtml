@model ProyectoAdminAviones.Model.Aerolinea

@{
    ViewData["Title"] = "Editar aerolínea";
}

<link rel="stylesheet" href="~/css/homepage.css" />
<link rel="stylesheet" href="~/css/crud.css" />

<div class="aviones-page">

    <section class="page-header">
        <div>
            <h1>AEROLÍNEAS</h1>
            <p>Gestiona y consulta las aerolíneas registradas en el sistema.</p>
        </div>

        <div class="page-actions">
            <a asp-action="Detalles" asp-route-id="@Model.IdAerolinea" class="btn-outline">
                <i class="fa-solid fa-arrow-left"></i>
                &nbsp;Volver
            </a>
        </div>
    </section>

    <section class="form-section">
        <div class="form-card">
            <div class="form-header">
                <h2>EDICIÓN</h2>
                <p>Actualiza los datos principales de la aerolínea registrada.</p>
            </div>

            <form asp-action="Editar">

                <div asp-validation-summary="ModelOnly" class="text-danger validation-summary"></div>

                <input asp-for="IdAerolinea" type="hidden" />

                <div class="form-grid">

                    <div class="form-group">
                        <label class="form-label">ID</label>
                        <input value="@Model.IdAerolinea" class="form-input" disabled />
                    </div>

                    <div class="form-group">
                        <label asp-for="Nombre" class="form-label">Nombre</label>
                        <input asp-for="Nombre" class="form-input" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Pais" class="form-label">País</label>
                        <input asp-for="Pais" class="form-input" />
                        <span asp-validation-for="Pais" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="FechaFundacion" class="form-label">Fecha de fundación</label>
                        <input asp-for="FechaFundacion" class="form-input" type="date" />
                        <span asp-validation-for="FechaFundacion" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Telefono" class="form-label">Teléfono</label>
                        <input asp-for="Telefono" class="form-input" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Correo" class="form-label">Correo</label>
                        <input asp-for="Correo" class="form-input" type="email" />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                </div>

                <div class="form-actions">
                    <button type="submit" class="btn">
                        <i class="fa-solid fa-floppy-disk"></i>
                        &nbsp;Guardar cambios
                    </button>

                    <a asp-action="Detalles" asp-route-id="@Model.IdAerolinea" class="btn-outline">
                        Cancelar
                    </a>
                </div>

            </form>
        </div>
    </section>

    <section class="cards-section">
        <div class="cards">
            <a asp-controller="GestionAviones" asp-action="Index" class="card">
                <i class="fa-solid fa-plane"></i>
                <h3>Aviones</h3>
                <p>Consulta y gestiona aeronaves registradas.</p>
            </a>

            <a asp-controller="GestionAerolineas" asp-action="Index" class="card">
                <i class="fa-solid fa-building"></i>
                <h3>Aerolíneas</h3>
                <p>Explora operadores y compañías aéreas.</p>
            </a>

            <a asp-controller="GestionPropietarios" asp-action="Index" class="card">
                <i class="fa-solid fa-user"></i>
                <h3>Propietarios</h3>
                <p>Accede a información de propietarios registrados.</p>
            </a>
        </div>
    </section>

    <footer class="footer">
        <p>Atlas Air Records © 2026</p>
    </footer>

</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}